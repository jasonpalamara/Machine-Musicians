                    "maxclass": "comment",
                    "numinlets": 1,
                    "numoutlets": 0,
                    "patching_rect": [ 169.0, 133.0, 152.0, 87.0 ],
                    "text": "Important takeaway:\nComments are useful for humans to understand what's going on in the patch, but they don't affect the patch."
                }
            },
